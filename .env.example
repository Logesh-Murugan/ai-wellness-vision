# AI WellnessVision Environment Configuration
# Copy this file to .env and fill in your actual values

# Application Settings
ENVIRONMENT=development
DEBUG=true
HOST=localhost
PORT=8501
API_PORT=8000

# Security
SECRET_KEY=your-secret-key-here-change-in-production
CORS_ORIGINS=http://localhost:3000,http://localhost:8501

# API Keys (Optional - for enhanced features)
OPENAI_API_KEY=your-openai-api-key-here
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Database Configuration
DATABASE_URL=sqlite:///./ai_wellness_vision.db
# For production PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/ai_wellness_vision

# Redis Configuration (Optional - for caching)
REDIS_URL=redis://localhost:6379/0
ENABLE_CACHE=true
CACHE_DEFAULT_TTL=3600

# Logging Configuration
LOG_LEVEL=INFO
USE_JSON_LOGGING=false
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Feature Flags
ENABLE_OFFLINE_MODE=true
ENABLE_VOICE_FEATURES=true
ENABLE_EXPLAINABLE_AI=true

# Performance Settings
MAX_UPLOAD_SIZE=10485760
REQUEST_TIMEOUT=30

# Monitoring (Optional)
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# Model Configuration
WHISPER_MODEL_SIZE=base
IMAGE_MODEL_NAME=resnet50

# Supported Languages (comma-separated)
SUPPORTED_LANGUAGES=en,hi,ta,te,bn,gu,mr
DEFAULT_LANGUAGE=en