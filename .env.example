# ============================================================
#  AI WellnessVision — Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# ============================================================

# ── Environment ────────────────────────────────
# Options: development | staging | production
ENVIRONMENT=development
DEBUG=true

# ── Server ─────────────────────────────────────
HOST=0.0.0.0
PORT=8000
API_PORT=8000

# ── Database (REQUIRED) ───────────────────────
# SQLite (dev only):
#   DATABASE_URL=sqlite:///./ai_wellness_vision.db
# PostgreSQL (recommended):
DATABASE_URL=postgresql://postgres:your-db-password-here@localhost:5432/ai_wellness_vision

# ── Redis (REQUIRED) ──────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Security / JWT (REQUIRED, min 32 chars) ───
# ⚠️  CHANGE THIS — generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=your-jwt-secret-min-32-chars-here-CHANGE-THIS

# JWT token configuration
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS Origins ──────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8501

# ── AI API Keys (optional) ────────────────────
# Gemini (Google) — primary AI engine
GEMINI_API_KEY=

# OpenAI — alternative AI engine
OPENAI_API_KEY=

# HuggingFace — model hub access
HUGGINGFACE_API_KEY=

# ── Upload & Rate Limits ──────────────────────
MAX_IMAGE_SIZE_MB=10
MAX_UPLOAD_SIZE=10485760
RATE_LIMIT_PER_MINUTE=60
REQUEST_TIMEOUT=30

# ── Feature Flags ─────────────────────────────
ENABLE_OFFLINE_MODE=true
ENABLE_VOICE_FEATURES=true
ENABLE_EXPLAINABLE_AI=true
ENABLE_CACHE=true

# ── Logging ───────────────────────────────────
LOG_LEVEL=INFO
USE_JSON_LOGGING=false

# ── Monitoring ────────────────────────────────
ENABLE_METRICS=true
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30

# ── Model Configuration ──────────────────────
IMAGE_MODEL_NAME=resnet50
WHISPER_MODEL_SIZE=base